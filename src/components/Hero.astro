---
import { Image } from 'astro:assets';
import { SITE_TAGLINE, ZENPLANNER_LOGIN_URL } from '../config/site';
import heroBg from '../assets/images/hero.webp';
---

<section class="hero" aria-label="Hero">
  <!-- Background photo -->
  <Image src={heroBg} alt="" class="hero-bg-photo" loading="eager" />
  <!-- Navy overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content container">
    <div class="hero-text">
      <!-- Headline -->
      <h1 class="hero-title">
        <span class="hero-title-line">Metro Tacoma</span>
        <span class="hero-title-line">Fencing Club</span>
      </h1>

      <!-- Tagline -->
      <p class="hero-tagline">{SITE_TAGLINE}</p>

      <!-- CTAs -->
      <div class="hero-ctas">
        <a href="/classes" class="btn btn-primary">
          View Classes
        </a>
        <a
          href={ZENPLANNER_LOGIN_URL}
          class="btn btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Login
        </a>
      </div>

      <!-- Stats strip -->
      <div class="hero-stats" role="list" aria-label="Club highlights">
        <div class="stat" role="listitem">
          <span class="stat-number">25+</span>
          <span class="stat-label">Years Active</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat" role="listitem">
          <span class="stat-number">Foil &amp; Épée</span>
          <span class="stat-label">Weapons</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat" role="listitem">
          <span class="stat-number">All Ages</span>
          <span class="stat-label">Programs</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: var(--nav-height);
  }

  /* Background photo */
  .hero-bg-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Navy overlay */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(4, 30, 66, 0.62);
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-20);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    animation: fadeUp 0.7s ease both;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    color: white;
    animation: fadeUp 0.7s ease 0.2s both;
  }

  .hero-title-line {
    display: block;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: var(--font-weight-medium);
    color: white;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    animation: fadeUp 0.7s ease 0.3s both;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    animation: fadeUp 0.7s ease 0.4s both;
  }

  /* Override outline button for dark hero background */
  .hero .btn-outline {
    border-color: white;
    color: white;
  }

  .hero .btn-outline:hover {
    border-color: var(--color-coral);
    color: var(--color-coral);
  }

  /* Stats strip */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    animation: fadeUp 0.7s ease 0.5s both;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-number {
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-coral);
    white-space: nowrap;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: rgba(209, 213, 219, 0.4);
    flex-shrink: 0;
  }
</style>
