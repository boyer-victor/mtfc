---
import { Image } from 'astro:assets';

interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  id: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="gallery-grid">
  {items.map((item) => (
    <div class="gallery-item">
      <a href={`#${item.id}`} class="gallery-link" aria-label={`View larger: ${item.alt}`}>
        <Image
          src={item.src}
          alt={item.alt}
          width={800}
          height={600}
          class="gallery-img"
        />
        <div class="gallery-overlay" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="expand-icon" aria-hidden="true">
            <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </a>

      <!-- CSS-only lightbox -->
      <div class="lightbox" id={item.id} role="dialog" aria-label={item.alt} aria-modal="true">
        <a href="#" class="lightbox-backdrop" aria-label="Close lightbox"></a>
        <figure class="lightbox-content">
          <Image
            src={item.src}
            alt={item.alt}
            width={800}
            height={600}
            class="lightbox-img"
          />
          <figcaption class="lightbox-caption">{item.alt}</figcaption>
          <a href="#" class="lightbox-close" aria-label="Close lightbox">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </a>
        </figure>
      </div>
    </div>
  ))}
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    aspect-ratio: 4/3;
  }

  .gallery-link {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.05);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 14, 14, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .expand-icon {
    width: 28px;
    height: 28px;
    color: var(--color-text-primary);
  }

  /* CSS-only lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-6);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .lightbox:target {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 14, 14, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(900px, 90vw);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .lightbox-img {
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .lightbox-caption {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-align: center;
  }

  .lightbox-close {
    position: absolute;
    top: calc(-1 * var(--space-10));
    right: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .lightbox-close:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-accent);
  }

  .lightbox-close svg {
    width: 18px;
    height: 18px;
  }
</style>
