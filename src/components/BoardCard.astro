---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role: string;
  bio: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { name, role, bio, image, imageAlt } = Astro.props;

function getInitials(fullName: string): string {
  return fullName
    .split(' ')
    .filter((part) => /^[A-Za-z]/.test(part))
    .slice(0, 2)
    .map((part) => part[0].toUpperCase())
    .join('');
}

const initials = getInitials(name);
---

<article class="board-card">
  <div class="board-photo">
    {image ? (
      <Image src={image} alt={imageAlt ?? name} width={400} height={533} class="board-img" />
    ) : (
      <div class="board-initials" aria-hidden="true">
        <span>{initials}</span>
      </div>
    )}
  </div>

  <div class="board-info">
    <p class="board-role">{role}</p>
    <h3 class="board-name">{name}</h3>
    <p class="board-bio">{bio}</p>
  </div>
</article>

<style>
  .board-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .board-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-3px);
  }

  .board-photo {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-gray-100);
  }

  .board-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .board-card:hover .board-img {
    transform: scale(1.04);
  }

  .board-initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a2744;
  }

  .board-initials span {
    font-size: 3.5rem;
    font-weight: var(--font-weight-semibold);
    color: #ffffff;
    letter-spacing: 0.05em;
    user-select: none;
  }

  .board-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    flex: 1;
  }

  .board-role {
    font-size: 0.7rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(248, 131, 121, 0.08);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-sm);
    display: inline-block;
    padding: 3px 10px;
    align-self: flex-start;
  }

  .board-name {
    font-size: 1.375rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin-top: var(--space-1);
  }

  .board-bio {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    flex: 1;
  }
</style>
