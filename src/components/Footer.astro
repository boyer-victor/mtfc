---
import {
  SITE_NAME,
  SITE_TAGLINE,
  SOCIAL,
  CONTACT_EMAIL,
  CONTACT_PHONE,
  CONTACT_HOURS,
  LOCATION,
  ADDRESS_STREET,
  EIN,
  ZENPLANNER_LOGIN_URL,
} from '../config/site';
import logoRaw from '../assets/icons/logo.svg?raw';
---

<footer class="footer">
  <div class="footer-inner container">

    <!-- Column 1: Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Metro Tacoma Fencing Club — Home">
        <span class="logo-svg" aria-hidden="true" set:html={logoRaw}></span>
      </a>
      <p class="footer-club-name">{SITE_NAME}</p>
      <p class="footer-tagline">{SITE_TAGLINE}</p>

      <!-- Social icons -->
      <div class="footer-social">
        {SOCIAL.instagram && (
          <a href={SOCIAL.instagram} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="MTFC on Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.75" fill="none"/>
              <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.75" fill="none"/>
              <circle cx="17.5" cy="6.5" r="1.25" fill="currentColor"/>
            </svg>
          </a>
        )}
        {SOCIAL.facebook && (
          <a href={SOCIAL.facebook} class="social-link" target="_blank" rel="noopener noreferrer" aria-label="MTFC on Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- Column 2: Contact -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Contact</h3>
      <ul role="list" class="footer-col-list">
        <li class="footer-address">
          <span>{ADDRESS_STREET}</span>
          <span>{LOCATION}</span>
        </li>
        <li>
          <a href={`tel:${CONTACT_PHONE.replace(/[^0-9]/g, '')}`} class="footer-link">{CONTACT_PHONE}</a>
        </li>
        <li>
          <a href={`mailto:${CONTACT_EMAIL}`} class="footer-link">{CONTACT_EMAIL}</a>
        </li>
        <li class="footer-hours">{CONTACT_HOURS}</li>
      </ul>
    </div>

    <!-- Column 3: Quick Links -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Quick Links</h3>
      <ul role="list" class="footer-col-list">
        <li><a href="/" class="footer-link">Home</a></li>
        <li><a href="/classes" class="footer-link">Classes</a></li>
        <li><a href="/about" class="footer-link">About</a></li>
        <li><a href="/faq" class="footer-link">FAQs</a></li>
        <li><a href="/gear" class="footer-link">Gear</a></li>
        <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- Column 4: Organization -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Organization</h3>
      <ul role="list" class="footer-col-list">
        <li class="footer-org-item">USA Fencing Club</li>
        <li class="footer-org-item">501(c)(3) Nonprofit</li>
        <li class="footer-org-item footer-ein">EIN: {EIN}</li>
        <li>
          <a href={ZENPLANNER_LOGIN_URL} class="footer-link footer-login-link" target="_blank" rel="noopener noreferrer">
            Login
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved.
      </p>
      <p class="footer-location">{LOCATION}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: var(--color-white);
    margin-top: auto;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-block: var(--space-16);
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* Column 1: Brand */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-logo {
    display: inline-flex;
  }

  .logo-svg :global(svg) {
    height: 64px;
    width: auto;
    display: block;
  }

  .footer-club-name {
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-white);
    letter-spacing: 0.02em;
    max-width: none;
    margin: 0;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    font-style: italic;
    max-width: none;
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    color: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .social-link:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.08);
  }

  .social-link svg {
    width: 18px;
    height: 18px;
  }

  /* Columns 2-4 */
  .footer-col-heading {
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .footer-col-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-coral);
  }

  .footer-address {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-hours {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  .footer-org-item {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-ein {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    font-family: var(--font-mono, monospace);
  }

  .footer-login-link {
    font-weight: var(--font-weight-medium);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--color-coral);
    padding-block: var(--space-5);
  }

  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .footer-bottom-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .footer-copy,
  .footer-location {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    max-width: none;
  }

  .footer-location {
    letter-spacing: 0.04em;
  }
</style>
