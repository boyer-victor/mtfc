---
import { ZENPLANNER_EMBED_URL } from '../config/site';
---

<section class="zenplanner-section">
  <div class="container">
    <div class="zenplanner-header">
      <span class="section-label">Registration</span>
      <h2 class="zenplanner-title">Enroll & Manage Membership</h2>
      <p class="zenplanner-desc">
        Register for classes, manage your membership, and track your attendance through our ZenPlanner portal.
      </p>
    </div>

    <div class="zenplanner-embed">
      <iframe
        src={ZENPLANNER_EMBED_URL}
        title="ZenPlanner membership and class registration portal"
        width="100%"
        height="600"
        frameborder="0"
        loading="lazy"
        class="zenplanner-frame"
      ></iframe>
    </div>

    <p class="zenplanner-note">
      Having trouble with the portal?
      <a href={ZENPLANNER_EMBED_URL} target="_blank" rel="noopener noreferrer" class="zenplanner-link">
        Open in a new tab
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M7 3H3a1 1 0 00-1 1v9a1 1 0 001 1h9a1 1 0 001-1V9M10 2h4v4M14 2L8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </p>
  </div>
</section>

<style>
  .zenplanner-section {
    padding-block: var(--space-20);
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
  }

  .zenplanner-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }

  .zenplanner-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: var(--font-weight-semibold);
  }

  .zenplanner-desc {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .zenplanner-embed {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    min-height: 600px;
  }

  .zenplanner-frame {
    display: block;
    min-height: 600px;
  }

  .zenplanner-note {
    margin-top: var(--space-4);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: none;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .zenplanner-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-accent);
    transition: gap var(--transition-fast);
  }

  .zenplanner-link:hover {
    gap: var(--space-2);
  }

  .zenplanner-link svg {
    width: 14px;
    height: 14px;
  }
</style>
