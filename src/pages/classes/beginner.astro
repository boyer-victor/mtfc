---
import ClassPageLayout from '../../components/ClassPageLayout.astro';

const pricing = [
  { label: '1 class/week', price: '$145/mo' },
  { label: 'Unlimited classes', price: '$180/mo' },
];
---

<ClassPageLayout
  title="Beginner Classes — Metro Tacoma Fencing Club"
  description="Build your fencing foundation with MTFC's beginner program — footwork, basic technique, and the rules of the strip."
  pageTitle="Beginner"
  pageSubtitle="Build your foundation from the ground up."
>
  <section class="section content-section">
    <div class="container content-body">
      <p>Our beginner program covers the essential building blocks of fencing: footwork, on-guard position, basic attacks and parries, and the rules of the strip. Classes are structured for adult and junior athletes new to the sport.</p>

      <div class="pricing-callout" aria-label="Beginner class pricing">
        <h2 class="pricing-heading">Pricing</h2>
        <table class="pricing-table" aria-label="Beginner class tuition">
          <tbody>
            {pricing.map((row) => (
              <tr class="pricing-row">
                <td class="pricing-td">{row.label}</td>
                <td class="pricing-td pricing-td-price">{row.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</ClassPageLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-body {
    max-width: 68ch;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .content-body > p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-primary);
  }

  .pricing-callout {
    background: var(--color-gray-100, #f5f5f5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .pricing-heading {
    padding: var(--space-4) var(--space-6);
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    margin: 0;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
  }

  .pricing-row {
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-row:last-child {
    border-bottom: none;
  }

  .pricing-td {
    padding: var(--space-4) var(--space-6);
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    background: #ffffff;
  }

  .pricing-td-price {
    text-align: right;
    font-weight: var(--font-weight-semibold);
    color: var(--color-navy);
    white-space: nowrap;
  }
</style>
