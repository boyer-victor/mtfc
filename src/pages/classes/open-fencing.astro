---
import ClassPageLayout from '../../components/ClassPageLayout.astro';
---

<ClassPageLayout
  title="Open Fencing — Metro Tacoma Fencing Club"
  description="Unstructured strip time for MTFC members — come fence, try new tactics, and build match experience. All weapons welcome."
  pageTitle="Open Fencing"
  pageSubtitle="Come fence — no instruction, just strip time."
>
  <section class="section content-section">
    <div class="container content-body">
      <p>Open fencing is unstructured strip time where club members fence each other at their own pace. It's a great way to get more touches in, try new tactics, and build match experience outside of class. All weapons welcome.</p>
      <p>Open fencing is run by Coach Andrew Glynn. Check the schedule for current days and times.</p>

      <div class="callout">
        <p>Hours and drop-in fees will be posted here — check back or contact us at <a href="mailto:info@tacomafencing.com">info@tacomafencing.com</a>.</p>
      </div>
    </div>
  </section>
</ClassPageLayout>

<style>
  .content-section {
    background: #ffffff;
  }

  .content-body {
    max-width: 68ch;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .content-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-primary);
  }

  .callout {
    background: var(--color-gray-100, #f5f5f5);
    border-left: 4px solid var(--color-coral);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .callout p {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .callout a {
    color: var(--color-coral);
    font-weight: var(--font-weight-semibold);
  }

  .callout a:hover {
    text-decoration: underline;
  }
</style>
