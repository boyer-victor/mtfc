---
import PageLayout from '../layouts/PageLayout.astro';
import CoachCard from '../components/CoachCard.astro';
import BoardCard from '../components/BoardCard.astro';
import { ADDRESS_STREET, LOCATION, EIN } from '../config/site';
import { coaches } from '../data/coaches';
import { board } from '../data/board';

const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L8 7H3l3.5 3.5L5 16l7-3.5 7 3.5-1.5-5.5L21 7h-5L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none"/></svg>`,
    name: 'Discipline',
    desc: 'Fencing rewards those who train with intention. We maintain high standards in every session — for athletes and coaches alike.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    name: 'Community',
    desc: 'We compete hard and support each other harder. MTFC is a club where athletes of every level belong and are challenged to grow.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    name: 'Excellence',
    desc: 'We measure success by competitive results, athlete development, and the quality of instruction — not enrollment numbers.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
    name: 'Safety',
    desc: 'Equipment standards, armorer oversight, and structured supervision on the strip. No shortcuts on safety — ever.',
  },
];

const stats = [
  { num: '1999', label: 'Founded' },
  { num: '501(c)(3)', label: 'Nonprofit' },
  { num: 'USA Fencing', label: 'Affiliated' },
  { num: EIN, label: 'EIN' },
];
---

<PageLayout
  title="About — Metro Tacoma Fencing Club"
  description="The history, mission, and values of Metro Tacoma Fencing Club — competitive fencing in Tacoma, WA since 1999."
>
  <!-- Page header -->
  <header class="page-header">
    <div class="page-header-bg" aria-hidden="true">
      <div class="header-blade"></div>
      <div class="epee-accent" aria-hidden="true">
        <svg viewBox="0 0 200 600" xmlns="http://www.w3.org/2000/svg" fill="none" class="epee-svg">
          <line x1="100" y1="580" x2="100" y2="80" stroke="#00e085" stroke-width="2.5" stroke-linecap="round" opacity="0.3"/>
          <ellipse cx="100" cy="80" rx="30" ry="16" stroke="#00e085" stroke-width="2" fill="none" opacity="0.4"/>
          <rect x="92" y="96" width="16" height="50" rx="4" fill="none" stroke="#1a6b5f" stroke-width="1.5" opacity="0.4"/>
          <ellipse cx="100" cy="152" rx="12" ry="8" stroke="#1a6b5f" stroke-width="1.5" fill="none" opacity="0.3"/>
        </svg>
      </div>
    </div>
    <div class="container">
      <span class="section-label">About the Club</span>
      <h1 class="page-title">Metro Tacoma<br/>Fencing Club</h1>
    </div>
  </header>

  <!-- Section 1: Club History / Info -->
  <section class="section history-section" aria-labelledby="history-heading">
    <div class="container">
      <div class="history-layout">
        <!-- Left: mission text -->
        <div class="history-text">
          <span class="section-label">Our Mission</span>
          <h2 id="history-heading">Built for Competitors,<br/>Open to Everyone</h2>
          <p>
            Metro Tacoma Fencing Club (MTFC) has been serving the South Puget Sound since 1999. We specialize in Olympic-style sport fencing, offering quality training in foil and épée to all ages and experience levels.
          </p>
          <p>
            MTFC is a 501(c)3 tax-exempt organization affiliated with the Western Washington Division of USA Fencing. Our coaches are qualified instructors in all three fencing weapons.
          </p>
          <p>
            We pride ourselves on an inclusive, friendly, and relaxed atmosphere where recreational fencers, beginners, and competitive athletes all train together.
          </p>
          <address class="club-address">
            <span>{ADDRESS_STREET}</span>
            <span>{LOCATION}</span>
          </address>
        </div>

        <!-- Right: stat callouts -->
        <div class="stat-callouts">
          {stats.map((stat) => (
            <div class="stat-item">
              <span class="stat-num">{stat.num}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Values sub-section -->
      <div class="values-subsection" aria-labelledby="values-heading">
        <div class="values-header">
          <span class="section-label">What We Stand For</span>
          <h2 id="values-heading">Club Values</h2>
        </div>
        <div class="values-grid">
          {values.map((value) => (
            <div class="value-card">
              <div class="value-icon" set:html={value.icon}></div>
              <h3 class="value-name">{value.name}</h3>
              <p class="value-desc">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Staff & Coaches -->
  <section class="section coaches-section" aria-labelledby="coaches-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Coaching Staff</span>
        <h2 id="coaches-heading">Our Coaches</h2>
      </div>
      <div class="coaches-grid">
        {coaches.map((coach) => (
          <CoachCard
            name={coach.name}
            title={coach.title}
            weapons={coach.weapons}
            bio={coach.bio}
            image={coach.image}
            imageAlt={coach.imageAlt}
            bookable={coach.bookable}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Board of Directors -->
  <section class="section board-section" aria-labelledby="board-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Leadership</span>
        <h2 id="board-heading">Board of Directors</h2>
      </div>
      <div class="board-grid">
        {board.map((member) => (
          <BoardCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            image={member.image}
            imageAlt={member.imageAlt}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Page header */
  .page-header {
    position: relative;
    padding: var(--space-20) 0 var(--space-16);
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .page-header-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .header-blade {
    position: absolute;
    width: 1.5px;
    height: 200%;
    top: -50%;
    right: 18%;
    background: linear-gradient(to bottom, transparent, rgba(248, 131, 121, 0.2), transparent);
    transform: rotate(-30deg);
  }

  .epee-accent {
    position: absolute;
    right: 8%;
    top: 0;
    height: 100%;
    width: 200px;
    opacity: 0.4;
  }

  .epee-svg {
    height: 100%;
    width: auto;
  }

  .page-title {
    margin-top: var(--space-3);
    color: var(--color-text-primary);
    line-height: 1.1;
  }

  /* Section 1: History / Info */
  .history-section {
    background: var(--color-bg);
  }

  .history-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .history-layout { grid-template-columns: 2fr 1fr; }
  }

  .history-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .history-text h2 { color: var(--color-text-primary); line-height: 1.2; }
  .history-text p { color: var(--color-text-secondary); font-size: 0.9375rem; }

  .club-address {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-style: normal;
  }

  .club-address span {
    font-size: 0.9rem;
    color: var(--color-text-primary);
  }

  /* Stat callouts */
  .stat-callouts {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-6);
    align-items: flex-start;
  }

  @media (min-width: 1024px) {
    .stat-callouts {
      flex-direction: column;
      flex-wrap: nowrap;
      border-left: 2px solid var(--color-accent);
      padding-left: var(--space-8);
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-num {
    font-size: 1.75rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* Values sub-section */
  .values-subsection {
    margin-top: var(--space-16);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .values-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
  }

  .values-header h2 { color: var(--color-text-primary); }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .values-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .value-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base);
  }

  .value-card:hover {
    border-color: var(--color-border-accent);
  }

  .value-icon {
    width: 36px;
    height: 36px;
    color: var(--color-accent);
  }

  .value-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .value-name {
    font-size: 1.0625rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .value-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  /* Section header (shared) */
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
  }

  .section-header h2 { color: var(--color-text-primary); }

  /* Section 2: Coaches */
  .coaches-section {
    background: var(--color-gray-100, #f3f4f6);
    border-top: 1px solid var(--color-border);
  }

  .coaches-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .coaches-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .coaches-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Section 3: Board */
  .board-section {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .board-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .board-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .board-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
