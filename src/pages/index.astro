---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import AnnouncementCard from '../components/AnnouncementCard.astro';
import { announcements } from '../data/announcements';
import { SOCIAL } from '../config/site';

const recentAnnouncements = announcements.slice(0, 3);

const classes = [
  {
    title: 'New to Fencing',
    description: 'Never held a sword? Start here — no experience needed.',
    href: '/classes/new-to-fencing',
  },
  {
    title: 'Beginner',
    description: 'Build foundations in footwork, technique, and basic actions.',
    href: '/classes/beginner',
  },
  {
    title: 'Intermediate',
    description: 'Refine your technique and start developing tactical play.',
    href: '/classes/intermediate',
  },
  {
    title: 'Advanced / Competitive',
    description: 'High-intensity training for tournament competitors.',
    href: '/classes/advanced',
  },
  {
    title: 'Private Lessons',
    description: 'One-on-one instruction with Coach Kim or Coach Chung.',
    href: '/classes/private',
  },
  {
    title: 'Open Fencing',
    description: 'Drop-in strip time — fence with whoever shows up.',
    href: '/classes/open-fencing',
  },
];
---

<PageLayout title="Metro Tacoma Fencing Club — Where Champions Are Forged">
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Class Blurbs -->
  <section class="section classes-section" aria-labelledby="classes-heading">
    <div class="container">
      <div class="section-header-centered">
        <span class="section-label">Programs</span>
        <h2 id="classes-heading" class="section-title">Our Classes</h2>
      </div>
      <div class="classes-grid">
        {classes.map((cls) => (
          <div class="class-card">
            <h3 class="class-card-title">{cls.title}</h3>
            <p class="class-card-desc">{cls.description}</p>
            <a href={cls.href} class="class-card-link" aria-label={`Learn more about ${cls.title}`}>
              Learn More →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. New to Fencing callout -->
  <section class="ntf-band" aria-labelledby="ntf-heading">
    <div class="container ntf-content">
      <div class="ntf-text">
        <h2 id="ntf-heading" class="ntf-title">Never held a sword?</h2>
        <p class="ntf-sub">Start here — no experience needed and loaner gear is available for your first session.</p>
      </div>
      <a href="/classes/new-to-fencing" class="btn btn-primary ntf-cta">
        Get Started
      </a>
    </div>
  </section>

  <!-- 4. Fencer Highlight -->
  <section class="section highlight-section" aria-labelledby="highlight-heading">
    <div class="container">
      <div class="section-header-centered">
        <span class="section-label">Spotlight</span>
        <h2 id="highlight-heading" class="section-title">Fencer Highlight</h2>
      </div>
      <div class="highlight-layout">
        <!-- Left column: placeholder card -->
        <div class="highlight-photo-col">
          <div class="highlight-placeholder" aria-label="Fencer highlight coming soon">
            <p class="highlight-placeholder-title">Fencer Highlight Coming Soon</p>
            <p class="highlight-placeholder-sub">Check back for a featured competitive athlete.</p>
          </div>
        </div>
        <!-- Right column: details (ready for real content) -->
        <div class="highlight-details-col">
          <p class="highlight-details-empty">Featured athlete details will appear here.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Announcements -->
  <section class="section announcements-section" aria-labelledby="announcements-heading">
    <div class="container">
      <div class="section-header">
        <div class="section-header-text">
          <span class="section-label">News</span>
          <h2 id="announcements-heading" class="section-title">Latest Announcements</h2>
        </div>
        <a href="/announcements" class="view-all" aria-label="View all announcements">
          View All →
        </a>
      </div>
      <div class="announcements-grid">
        {recentAnnouncements.map((a) => (
          <AnnouncementCard announcement={a} />
        ))}
      </div>

      <!-- Follow Us -->
      {(SOCIAL.instagram || SOCIAL.facebook) && (
        <div class="follow-row" aria-label="Follow us on social media">
          <span class="follow-label">Follow Us</span>
          <div class="follow-icons">
            {SOCIAL.instagram && (
              <a
                href={SOCIAL.instagram}
                class="follow-icon-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="follow-icon">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
                </svg>
              </a>
            )}
            {SOCIAL.facebook && (
              <a
                href={SOCIAL.facebook}
                class="follow-icon-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="follow-icon">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>

<style>
  /* ─── Section header helpers ─────────────────────────────── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .section-header-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .section-title {
    color: var(--color-text-primary);
  }

  .section-header-centered {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
    white-space: nowrap;
    transition: gap var(--transition-fast);
  }

  .view-all:hover { gap: var(--space-3); }

  /* ─── 2. Class Blurbs ────────────────────────────────────── */
  .classes-section {
    background: #ffffff;
  }

  .classes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .classes-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .classes-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .class-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background: #ffffff;
    border: 1px solid var(--color-gray-300, #d1d5db);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .class-card:hover {
    border-color: var(--color-coral);
    transform: translateY(-2px);
  }

  .class-card-title {
    font-size: 1.125rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .class-card-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .class-card-link {
    font-size: 0.8125rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-coral);
    transition: letter-spacing var(--transition-fast);
    align-self: flex-start;
  }

  .class-card-link:hover { letter-spacing: 0.02em; }

  /* ─── 3. New to Fencing callout ─────────────────────────── */
  .ntf-band {
    background: var(--color-navy);
    padding-block: var(--space-16);
  }

  .ntf-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .ntf-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .ntf-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 520px;
  }

  .ntf-title {
    color: #ffffff;
  }

  .ntf-sub {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    line-height: 1.6;
  }

  .ntf-cta {
    flex-shrink: 0;
  }

  /* ─── 4. Fencer Highlight ────────────────────────────────── */
  .highlight-section {
    background: #ffffff;
  }

  .highlight-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .highlight-layout {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .highlight-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    background: var(--color-navy);
    border-radius: var(--radius-xl);
    padding: var(--space-16) var(--space-8);
    text-align: center;
    min-height: 260px;
  }

  .highlight-placeholder-title {
    font-size: 1.125rem;
    font-weight: var(--font-weight-semibold);
    color: #ffffff;
  }

  .highlight-placeholder-sub {
    font-size: 0.9rem;
    color: var(--color-gray-400, #9ca3af);
  }

  .highlight-details-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .highlight-details-empty {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* ─── 5. Announcements ───────────────────────────────────── */
  .announcements-section {
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
  }

  .announcements-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .announcements-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .announcements-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Follow Us */
  .follow-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .follow-label {
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .follow-icons {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .follow-icon-link {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .follow-icon-link:hover {
    color: var(--color-coral);
    transform: translateY(-2px);
  }

  .follow-icon {
    width: 22px;
    height: 22px;
    display: block;
  }
</style>
