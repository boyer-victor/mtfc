---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Privacy Policy — Metro Tacoma Fencing Club"
  description="Privacy Policy for Metro Tacoma Fencing Club."
>
  <div class="privacy-container">
    <h1>Privacy Policy</h1>
    <p>Metro Tacoma Fencing Club — Last updated: June 2026.</p>
    <p>This privacy policy will be fully updated before public launch. For questions in the meantime, contact us at info@tacomafencing.com.</p>
  </div>
</PageLayout>

<style>
  .privacy-container {
    max-width: 820px;
    margin: 0 auto;
    padding: var(--space-16);
    background: var(--color-bg);
  }

  h1 {
    color: var(--color-text-primary);
    font-size: 2rem;
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-6);
  }

  p {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }
</style>
